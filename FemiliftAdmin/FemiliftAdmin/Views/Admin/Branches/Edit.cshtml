@model FemiliftAdmin.Models.ViewModels.BranchEditViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "編輯院所";
}

<div class="admin-card">
    <div class="admin-card-header">
        <h2>編輯院所：@Model.Name</h2>
    </div>

    @using (Html.BeginForm("Edit", "Branches", new { id = Model.Id }, FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)

        <div class="form-group">
            @Html.LabelFor(m => m.Name)
            @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Name)
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.Phone)
            @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Phone)
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.Hours)
            @Html.TextAreaFor(m => m.Hours, new { @class = "form-control", rows = 4 })
            @Html.ValidationMessageFor(m => m.Hours)
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.Address)
            @Html.TextBoxFor(m => m.Address, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Address)
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.MapUrl)
            @Html.TextBoxFor(m => m.MapUrl, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.MapUrl)
        </div>
        <div class="form-group">
            <label>院所圖片</label>
            @if (!string.IsNullOrEmpty(Model.ExistingImagePath))
            {
                <div>
                    <img id="image-preview"
                         src="~/@Model.ExistingImagePath"
                         data-existing="@Model.ExistingImagePath"
                         class="image-preview" />
                </div>
                <label style="margin-top:8px;">
                    <input type="checkbox" name="RemoveImage" id="RemoveImage" value="true" /> 移除目前圖片
                </label>
                @Html.Hidden("ExistingImagePath", Model.ExistingImagePath)
            }
            else
            {
                <img id="image-preview" style="display:none;" class="image-preview" />
            }
            <input type="file" name="ImageFile" id="ImageFile" accept=".jpg,.jpeg,.png,.webp" class="form-control" style="margin-top:8px;" />
            <small style="color:#888;">建議尺寸 600x400，支援 jpg/png/webp，上限 2MB</small>
            @Html.ValidationMessageFor(m => m.ImageFile)
        </div>

        <div class="form-group">
            <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                @Html.CheckBoxFor(m => m.IsVisible)
                <span>顯示於前台</span>
            </label>
        </div>

        <button type="submit" class="btn btn-primary">儲存</button>
        <a href="@Url.Action("Index")" class="btn btn-secondary">取消</a>
    }

    <hr style="margin:24px 0;" />
    @using (Html.BeginForm("Delete", "Branches", new { id = Model.Id }, FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger btn-delete">刪除此院所</button>
    }
</div>
