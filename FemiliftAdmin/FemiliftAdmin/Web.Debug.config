<?xml version="1.0"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <connectionStrings>
    <add name="FemiliftDb"
      connectionString="Server=(localdb)\MSSQLLocalDB;Database=FemiliftAdmin;Integrated Security=True;MultipleActiveResultSets=True"
      providerName="System.Data.SqlClient"
      xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
  </connectionStrings>
</configuration>
